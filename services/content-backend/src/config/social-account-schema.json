{
  "platforms": [
    {
      "platform": "youtube",
      "label": "YouTube",
      "description": "Store the credentials needed to publish videos to your YouTube channel.",
      "fields": [
        {
          "key": "accountLabel",
          "label": "Account Label",
          "type": "text",
          "required": true,
          "placeholder": "Run4Dream YouTube"
        },
        {
          "key": "channelId",
          "label": "Channel ID",
          "type": "text",
          "required": true,
          "placeholder": "UCxxxxxxxxxxxxxxxx"
        },
        {
          "key": "googleClientId",
          "label": "Google Client ID",
          "type": "text",
          "required": true
        },
        {
          "key": "googleClientSecret",
          "label": "Google Client Secret",
          "type": "password",
          "required": true
        },
        {
          "key": "accessToken",
          "label": "Access Token",
          "type": "password",
          "required": true
        },
        {
          "key": "refreshToken",
          "label": "Refresh Token",
          "type": "password",
          "required": true
        },
        {
          "key": "redirectUri",
          "label": "Redirect URI",
          "type": "url",
          "required": true,
          "placeholder": "http://localhost:3000/social-accounts"
        },
        {
          "key": "tokenExpiresAt",
          "label": "Token Expires At",
          "type": "datetime-local",
          "required": false
        },
        {
          "key": "scopes",
          "label": "Scopes",
          "type": "textarea",
          "required": false,
          "rows": 2,
          "placeholder": "youtube.upload, youtube.readonly"
        },
        {
          "key": "notes",
          "label": "Notes",
          "type": "textarea",
          "required": false,
          "rows": 2,
          "placeholder": "Any internal notes for this connection"
        }
      ]
    },
