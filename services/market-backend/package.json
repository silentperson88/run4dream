{
  "name": "market-backend-pg",
  "version": "1.0.0",
  "description": "Market backend microservice with PostgreSQL persistence",
  "main": "server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "worker:fundamentals": "node src/workers/fundamentals.worker.js",
    "worker:fundamentals:test": "node src/workers/fundamentals.parallel.worker.js --once",
    "worker:fundamentals:parallel": "node src/workers/fundamentals.parallel.worker.js",
    "worker:fundamentals:overview": "node src/workers/fundamentals.overview.worker.js",
    "worker:fundamentals:quarterly": "node src/workers/fundamentals.quarterly.worker.js",
    "worker:fundamentals:profit-loss": "node src/workers/fundamentals.split.worker.js --section=profit_loss",
    "worker:fundamentals:profit-loss:test": "node src/workers/fundamentals.split.worker.js --section=profit_loss --once",
    "worker:fundamentals:balance-sheet": "node src/workers/fundamentals.split.worker.js --section=balance_sheet",
    "worker:fundamentals:balance-sheet:test": "node src/workers/fundamentals.split.worker.js --section=balance_sheet --once",
    "worker:fundamentals:cash-flow": "node src/workers/fundamentals.split.worker.js --section=cash_flow",
    "worker:fundamentals:cash-flow:test": "node src/workers/fundamentals.split.worker.js --section=cash_flow --once",
    "worker:fundamentals:ratios": "node src/workers/fundamentals.split.worker.js --section=ratios",
    "worker:fundamentals:ratios:test": "node src/workers/fundamentals.split.worker.js --section=ratios --once",
    "worker:fundamentals:shareholding": "node src/workers/fundamentals.split.worker.js --section=shareholdings",
    "worker:fundamentals:shareholding:test": "node src/workers/fundamentals.split.worker.js --section=shareholdings --once",
    "worker:fundamentals:split:all": "node src/workers/fundamentals.split.all.worker.js",
    "worker:fundamentals:split:all:test": "node src/workers/fundamentals.split.all.worker.js --once",
    "worker:fundamentals:pending": "node src/workers/fundamentals.parallel.worker.js --mode=pending",
    "worker:fundamentals:failed": "node src/workers/fundamentals.parallel.worker.js --mode=failed",
    "worker:fundamentals:pending-failed": "node src/workers/fundamentals.parallel.worker.js --mode=pending,failed",
    "worker:fundamentals:refresh": "node src/workers/fundamentals.parallel.worker.js --mode=refresh",
    "worker:fundamentals:all": "node src/workers/fundamentals.parallel.worker.js --mode=all",
    "migrate": "node src/db/migrate.js",
    "seed:rawstocks": "node src/scripts/rawstocks.script.js",
    "seed:rawstocks:local": "node src/scripts/rawstocks.fromRawData.script.js",
    "worker:rawstocks:to-master": "node src/workers/rawstocks.to-master.worker.js",
    "worker:rawstocks:to-master:test": "node src/workers/rawstocks.to-master.worker.js --once",
    "worker:active-stocks:price-refresh": "node src/workers/active-stocks.price-refresh.worker.js",
    "worker:active-stocks:price-refresh:test": "node src/workers/active-stocks.price-refresh.worker.js --once",
    "sync:eq:auto-activate": "node src/scripts/auto-activate-eq.script.js",
    "sync:eod:missing-history": "node src/scripts/fetch-missing-eod-history.script.js",
    "sync:eod:remap-master-id": "node src/scripts/eod.remap-master-id.script.js",
    "worker:eod:derived": "node src/workers/eod.derived-metrics.worker.js",
    "worker:eod:derived:test": "node src/workers/eod.derived-metrics.worker.js --once",
    "worker:eod:derived:dry-run": "node src/workers/eod.derived-metrics.worker.js --dry-run --once"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.13.1",
    "cheerio": "^1.0.0-rc.12",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "express-validator": "^7.3.1",
    "ioredis": "^5.9.1",
    "node-cron": "^4.2.1",
    "pg": "^8.13.1",
    "playwright": "^1.49.0",
    "smartapi-javascript": "^1.0.27",
    "uuid": "^11.0.5",
    "winston": "^3.18.3",
    "ws": "^8.19.0",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "nodemon": "^3.1.9"
  }
}
