{
  "name": "postgressserver",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev:market": "npm --prefix services/market-backend run dev",
    "dev:user": "npm --prefix services/user-backend run dev",
    "dev:gateway": "npm --prefix gateway run dev",
    "start:market": "npm --prefix services/market-backend run start",
    "start:user": "npm --prefix services/user-backend run start",
    "start:gateway": "npm --prefix gateway run start",
    "migrate:market": "npm --prefix services/market-backend run migrate",
    "migrate:user": "npm --prefix services/user-backend run migrate"
  }
}
