# Keep runtime secrets and local overrides out of git.
**/.env
**/.env.*
!**/.env.example
!**/.env.sample

# Dependencies
**/node_modules/

# Build output
**/dist/
**/build/
**/.next/
**/coverage/

# Runtime data and generated files
**/tmp/
**/temp/
**/rawData/
**/generated-audio/
**/uploads/
**/checking.js
**/*.log
